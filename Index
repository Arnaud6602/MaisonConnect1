<style>
:root{
  --bg1:#0f2027;
  --bg2:#203a43;
  --bg3:#2c5364;
  --card:#151922;
  --accent:#4fd1c5;
  --text:#ffffff;
  --muted:#b5b5b5;
}
*{box-sizing:border-box;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial}
body{
  margin:0;
  background:linear-gradient(135deg,var(--bg1),var(--bg2),var(--bg3));
  color:var(--text);
}
.container{
  max-width:1100px;
  margin:auto;
  padding:25px 15px 80px;
}
header{text-align:center;margin-bottom:35px}
h1{margin:0;font-size:2.4rem}
.subtitle{color:var(--muted);margin-top:8px}
.section{margin-top:40px}
.packs{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:20px}
.card{
  background:var(--card);
  border-radius:18px;
  padding:22px;
  box-shadow:0 10px 25px rgba(0,0,0,.4);
}
.price{
  font-size:2.1rem;
  color:var(--accent);
  margin:8px 0;
}
ul{padding-left:18px;line-height:1.6}
.option{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin:10px 0;
}
.counter{
  display:flex;
  gap:8px;
  align-items:center;
}
.counter button{
  width:32px;
  height:32px;
  border-radius:8px;
  border:none;
  font-size:18px;
  background:var(--accent);
  cursor:pointer;
}
.counter span{
  min-width:25px;
  text-align:center;
}
.total{
  margin-top:20px;
  font-size:1.4rem;
  text-align:center;
}
.btn{
  display:block;
  width:100%;
  margin-top:15px;
  padding:14px;
  border-radius:14px;
  border:none;
  background:var(--accent);
  font-size:1.05rem;
  font-weight:600;
  cursor:pointer;
  text-align:center;
}
.footer{
  margin-top:60px;
  text-align:center;
  color:var(--muted);
  font-size:.9rem;
}
</style>
</head>

